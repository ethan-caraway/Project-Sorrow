  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: The Fox & The Lion
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 61
  title: The Fox & The Lion
  author: Walter Crane
  isFemaleAuthor: 0
  stanzas:
  - lines:
    - The first time the Fox had a sight
    - Of the Lion, he 'most died of fright;
    - When he next met his eye,
    - Fox felt just a bit shy;
    - But the next - quite at ease, & polite.
  - lines:
    - Familiarity Destroys Fear
  rating: 0
