  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: The Four Ages Of Man
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 33
  title: The Four Ages Of Man
  author: William Butler Yeats
  stanzas:
  - lines:
    - He with body waged a fight,
    - But body won; it walks upright.
    - Then he struggled with the heart;
    - Innocence and peace depart.
    - Then he struggled with the mind;
    - His proud heart he left behind.
    - Now his wars on God begin;
    - At stroke of midnight God shall win.
  rating: 1
