  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: To His Household Gods
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 78
  title: To His Household Gods
  author: Robert Herrick
  isFemaleAuthor: 0
  stanzas:
  - lines:
    - Rise, household gods, and let us go;
    - But whither I myself not know.
    - First, let us dwell on rudest seas;
    - Next, with severest savages;
    - Last, let us make our best abode
    - 'Where human foot as yet ne''er trod:'
    - Search worlds of ice, and rather there
    - Dwell than in loathed Devonshire.
  rating: 1
