  m_Name: To fill a Gap
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 56
  title: To fill a Gap
  author: Emily Dickenson
  isFemaleAuthor: 1
  stanzas:
  - lines:
    - To fill a Gap
    - Insert the Thing that caused it -
    - Block it up
    - With Other - and 'twill yawn the more -
    - You cannot solder an Abyss
    - With Air.
  rating: 0
