  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: Theme in Yellow
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 58
  title: Theme in Yellow
  author: Carl Sandburg
  isFemaleAuthor: 0
  stanzas:
  - lines:
    - I spot the hills
    - With yellow balls in autumn.
    - I light the prairie cornfields
    - Orange and tawny gold clusters
    - And I am called pumpkins.
    - On the last of October
    - When dusk is fallen
    - Children join hands
    - And circle round me
    - Singing ghost songs
    - And love to the harvest moon;
    - I am a jack-o'-lantern
    - With terrible teeth
    - And the children know
    - I am fooling.
  rating: 1
