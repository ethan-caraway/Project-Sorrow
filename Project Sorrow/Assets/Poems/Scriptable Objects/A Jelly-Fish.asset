  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: A Jelly-Fish
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 57
  title: A Jelly-Fish
  author: Marianne Moore
  isFemaleAuthor: 1
  stanzas:
  - lines:
    - Visible, invisible,
    - A fluctuating charm,
    - An amber-colored amethyst
    - Inhabits it; your arm
    - Approaches, and
    - It opens and
    - It closes;
    - You have meant
    - To catch it,
    - And it shrivels;
    - You abandon
    - Your intent -
    - It opens, and it
    - Closes and you
    - Reach for it -
    - The blue
    - Surrounding it
    - Grows cloudy, and
    - It floats away
    - From you.
  rating: 2
