  m_Name: Dirce
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 72
  title: Dirce
  author: Walter Savage Lander
  isFemaleAuthor: 0
  stanzas:
  - lines:
    - Stand close around, ye Stygian set,
    - With Dirce in one boat conveyed,
    - Or Charon, seeing, may forget
    - That he is old and she a shade.
  rating: 0
