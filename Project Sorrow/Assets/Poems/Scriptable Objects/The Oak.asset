  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: The Oak
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 34
  title: The Oak
  author: Alfred Lord Tennyson
  stanzas:
  - lines:
    - Live thy Life,
    - Young and old,
    - Like yon oak,
    - Bright in spring,
    - Living gold;
  - lines:
    - Summer-rich
    - Then; and then
    - Autumn-changed
    - Soberer-hued
    - Gold again.
  - lines:
    - All his leaves
    - Fall'n at length,
    - Look, he stands,
    - Trunk and bough
    - Naked strength.
  rating: 1
