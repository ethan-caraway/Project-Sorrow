  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: Void
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 59
  title: Void
  author: Emily Dickinson
  isFemaleAuthor: 1
  stanzas:
  - lines:
    - Great streets of silence led away
    - To neighborhoods of pause;
    - Here was no notice, no dissent,
    - No universe, no laws.
  - lines:
    - By clocks 't was morning, and for night
    - The bells at distance called;
    - But epoch had no basis here,
    - For period exhaled.
  rating: 1
