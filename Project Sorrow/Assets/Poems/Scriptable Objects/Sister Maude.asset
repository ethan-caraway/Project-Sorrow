  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: Sister Maude
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 27
  title: Sister Maude
  author: Christina Georgina Rossetti
  isFemaleAuthor: 1
  stanzas:
  - lines:
    - Who told my mother of my shame,
    - '    Who told my father of my dear?'
    - Oh who but Maude, my sister Maude,
    - '    Who lurked to spy and peer.'
  - lines:
    - Cold he lies, as cold as stone,
    - '    With his clotted curls about his face:'
    - The comeliest corpse in all the world
    - '    And worthy of a queen''s embrace.'
  - lines:
    - You might have spared his soul, sister,
    - '    Have spared my soul, your own soul too:'
    - Though I had not been born at all,
    - '    He''d never have looked at you.'
  - lines:
    - My father may sleep in Paradise,
    - '    My mother at Heaven-gate:'
    - But sister Maude shall get no sleep
    - '    Either early or late.'
  - lines:
    - My father may wear a golden gown,
    - '    My mother a crown may win;'
    - If my dear and I knocked at Heaven-gate
    - '    Perhaps they''d let us in:'
    - But sister Maude, oh sister Maude,
    - '    Bide you with death and sin.'
  rating: 3
