  m_Script: {fileID: 11500000, guid: b492ab769d202ee4183275be4bff9429, type: 3}
  m_Name: To Anthea
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Poems.PoemScriptableObject
  id: 69
  title: To Anthea
  author: Robert Herrick
  isFemaleAuthor: 0
  stanzas:
  - lines:
    - Anthea, I am going hence
    - With some small stock of innocence;
    - But yet those blessed gates I see
    - Withstanding entrance unto me;
    - To pray for me do thou begin;
    - The porter then will let me in.
  rating: 0
