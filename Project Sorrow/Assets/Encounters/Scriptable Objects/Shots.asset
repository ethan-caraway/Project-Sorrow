  m_Name: Shots
  m_EditorClassIdentifier: Assembly-CSharp::FlightPaper.ProjectSorrow.Encounters.EncounterScriptableObject
  id: 10
  title: Shots!
  description: 'You see a group of other poets being a bit rowdy at the bar.


    One
    of the women invites you to join in. The group is ordering a round of shots,
    and the woman insists you do one too.'
  options:
  - title: Do a shot
    description: Become <color=#828282>Impaired (x3)</color>
    conclusion: 'Your throat burns as it goes down. It''s much stronger than you
      had anticipated, and you''re already starting to feel it.


      This is going
      to make things more difficult. '
    isHidden: 0
    item: {fileID: 0}
    consumable: {fileID: 0}
    tag: Impaired
  - title: Refuse
    description: <color=red>-5</color> reputation
    conclusion: '"Boo!"


      Some of the other poets join in with their disapproval.
      You take this as your sign to leave. '
    isHidden: 0
    item: {fileID: 0}
    consumable: {fileID: 0}
    tag: Reputation
  minRound: 2
  rarity: 1
